# ============================================================
# Error Code Explorer – .htaccess Performance & SEO v3
# ============================================================

# --- Force HTTPS (uncomment if SSL is configured) ---
# RewriteEngine On
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# --- Remove trailing slash from /error/id → canonical /error/id/ ---
# Already handled by DirectorySlash On (default Apache)

# ============================================================
# SECURITY HEADERS
# ============================================================
<IfModule mod_headers.c>
    # Prevent clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"

    # Prevent MIME sniffing
    Header always set X-Content-Type-Options "nosniff"

    # Enable XSS protection in older browsers
    Header always set X-XSS-Protection "1; mode=block"

    # Referrer policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Permissions policy – disable unused browser features
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), interest-cohort=()"

    # Content Security Policy
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://formspree.io https://cloud.umami.is https://www.googletagmanager.com https://pagead2.googlesyndication.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: https:; connect-src 'self' https://formspree.io https://cloud.umami.is https://www.google-analytics.com; frame-src https://www.google.com; frame-ancestors 'self';"

    # HSTS – enable only with valid SSL
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Remove server info headers
    Header unset Server
    Header unset X-Powered-By

    # --- Vary headers for correct caching ---
    <FilesMatch "\.(js|css|html|json)$">
        Header append Vary Accept-Encoding
    </FilesMatch>
</IfModule>

# ============================================================
# BROTLI COMPRESSION (mod_brotli – Apache 2.4.26+)
# Falls back gracefully to GZIP if not available
# ============================================================
<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/css text/javascript application/javascript application/x-javascript application/json application/xml text/xml image/svg+xml
    BrotliCompressionQuality 6
</IfModule>

# ============================================================
# GZIP COMPRESSION FALLBACK (mod_deflate)
# ============================================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/x-javascript application/json application/xml text/xml image/svg+xml
    # Bug fixes for some browsers
    BrowserMatch ^Mozilla/4 gzip-only-text/html
    BrowserMatch ^Mozilla/4\.0[678] no-gzip
    BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
</IfModule>

# ============================================================
# CACHE-CONTROL HEADERS
# ============================================================
<IfModule mod_headers.c>
    # JS/CSS – 30 days (cache-busted via ?v= or filename hash)
    <FilesMatch "\.(js|css)$">
        Header set Cache-Control "public, max-age=2592000, stale-while-revalidate=86400"
    </FilesMatch>

    # Images – 6 months, immutable
    <FilesMatch "\.(png|jpg|jpeg|gif|webp|svg|ico)$">
        Header set Cache-Control "public, max-age=15552000, immutable"
    </FilesMatch>

    # Fonts – 1 year, immutable
    <FilesMatch "\.(woff2|woff|ttf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # Static error pages (/error/*/index.html) – 1 hour, then revalidate
    # These are pre-rendered so can be cached longer than the SPA shell
    <FilesMatch "\.html$">
        Header set Cache-Control "public, max-age=3600, must-revalidate"
    </FilesMatch>

    # XML sitemaps + JSON – 24 hours
    <FilesMatch "\.(xml|json)$">
        Header set Cache-Control "public, max-age=86400"
    </FilesMatch>
</IfModule>

# ============================================================
# BROWSER CACHING (mod_expires)
# ============================================================
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    ExpiresByType text/html "access plus 1 hour"
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType application/x-javascript "access plus 1 year"
    ExpiresByType image/webp "access plus 6 months"
    ExpiresByType image/png "access plus 6 months"
    ExpiresByType image/jpeg "access plus 6 months"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 6 months"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/xml "access plus 1 day"
    ExpiresByType text/xml "access plus 1 day"
</IfModule>

# ============================================================
# ETAGS
# ============================================================
FileETag MTime Size

# ============================================================
# DISABLE DIRECTORY LISTING
# ============================================================
Options -Indexes

# ============================================================
# PROTECT SENSITIVE FILES
# ============================================================
<FilesMatch "(\.htaccess|\.htpasswd|\.env|\.git|package\.json|composer\.json|split\.ps1|generate\.js|generate\.ps1|data\.js\.map)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# ============================================================
# SEO: CLEAN URLS + ROUTING
# ============================================================
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Force HTTPS (uncomment after enabling SSL)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Remove www (uncomment if needed)
    # RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    # RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

    # Language shortcuts: /en → /?lang=en
    RewriteRule ^(en|zh|cs)/?$ /?lang=$1 [L,QSA]

    # Serve /error/{id}/ pages directly – Apache handles index.html natively
    # This rule handles /error/{id} (without trailing slash) → 301 to canonical
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^error/([^/]+)$ /error/$1/ [R=301,L]

    # If /error/{id}/index.html exists, serve it directly (no SPA fallback)
    RewriteCond %{DOCUMENT_ROOT}/error/$1/index.html -f
    RewriteRule ^error/([^/]+)/?$ /error/$1/index.html [L]
</IfModule>

# ============================================================
# CUSTOM ERROR DOCUMENTS
# ============================================================
ErrorDocument 404 /index.html
ErrorDocument 403 /index.html

# ============================================================
# HTTP/2 SERVER PUSH (Link headers) – uncomment if host supports it
# Pushes critical resources when the homepage is requested
# ============================================================
<FilesMatch "^index\.html$">
    Header add Link "</index.css>; rel=preload; as=style"
    Header add Link "</index.js>; rel=preload; as=script"
    Header add Link "</data.js>; rel=preload; as=script"
    Header add Link "</favicon.png?v=1>; rel=preload; as=image"
</FilesMatch>

